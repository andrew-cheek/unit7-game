    "shots": "node scripts/shoot.mjs",
    "party:dev": "partykit dev",
    "party:deploy": "partykit deploy"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "three": "0.160.0"
  },
  "devDependencies": {
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@types/three": "0.160.0",
    "@vitejs/plugin-react": "4.2.1",
    "partykit": "0.0.111",
    "playwright-core": "^1.61.1",
    "typescript": "5.4.5",
    "vite": "5.2.11"
  }
}
