{
  "name": "unit7-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Unit 7 — a polished futuristic third-person sci-fi browser game in Three.js, packaged as a single embeddable React component <Unit7Game />.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
